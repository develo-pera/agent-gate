# ── Network (Base mainnet) ────────────────────────────────────────────
# Custom RPC endpoint (optional — defaults to https://mainnet.base.org)
# RPC_URL=https://mainnet.base.org

# ── L1 Ethereum RPC (for Lido stETH reads) ───────────────────────────
# Used by Lido tools to read stETH protocol state on L1 (APR, balances, shares)
# Defaults to https://eth.llamarpc.com (free, rate-limited)
# L1_RPC_URL=https://eth.llamarpc.com

# ── Wallet ──────────────────────────────────────────────────────────
# Private key for signing transactions (omit for read-only mode)
# PRIVATE_KEY=0x...

# ── Contracts ───────────────────────────────────────────────────────
# AgentTreasury deployment address on Base (set after deploying)
TREASURY_ADDRESS=0x21743309154f5176DB531c5f8226e7EA666d3E49
NEXT_PUBLIC_TREASURY_ADDRESS=0x21743309154f5176DB531c5f8226e7EA666d3E49

# ── Uniswap ─────────────────────────────────────────────────────────
# Developer Platform API key from https://app.uniswap.org/developers
# Required for live quotes and swap execution
UNISWAP_API_KEY=

# ── Dashboard App ───────────────────────────────────────────────────
# WalletConnect project ID (get free at https://cloud.walletconnect.com)
NEXT_PUBLIC_WC_PROJECT_ID=demo

# Demo mode treasury address shown when no wallet is connected
NEXT_PUBLIC_DEMO_TREASURY_ADDRESS=0x770323A064435C282CD97Cc2C71e668ad89336b9
