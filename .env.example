# ── Network ─────────────────────────────────────────────────────────
# RPC endpoint (auto-detected from CHAIN if not set)
# RPC_URL=https://mainnet.base.org

# Chain: "base" (default) | "mainnet" | "arbitrum" | "holesky"
# Base is recommended: cheapest gas, has wstETH + Uniswap Trading API support
CHAIN=base

# ── Wallet ──────────────────────────────────────────────────────────
# Private key for signing transactions (omit for read-only mode)
# PRIVATE_KEY=0x...

# ── Dry Run ─────────────────────────────────────────────────────────
# Set to "true" to simulate all write operations (recommended for testing)
DRY_RUN=true

# ── Contracts ───────────────────────────────────────────────────────
# AgentTreasury deployment address (set after deploying)
# TREASURY_ADDRESS=0x...

# ── Uniswap ─────────────────────────────────────────────────────────
# Developer Platform API key from https://app.uniswap.org/developers
# Required for live quotes and swap execution
# UNISWAP_API_KEY=...
